# =============================================================================
# KRX Data Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# --- Database (PostgreSQL) ---------------------------------------------------
# Preferred: single DSN string
DB_DSN=postgresql://krx_user:changeme@localhost:5432/krx_data

# Alternative: individual components (used if DB_DSN is empty)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=krx_data
# DB_USER=krx_user
# DB_PASSWORD=changeme

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=plain          # plain | json
# LOG_DIR=                # optional; set to enable rotating file handler

# --- Runtime -----------------------------------------------------------------
RUN_MODE=dev              # dev | prod

# --- Universe sync defaults --------------------------------------------------
UNIVERSE_SOURCE_DEFAULT=fdr    # fdr | pykrx

# --- KRX / pykrx -------------------------------------------------------------
# Required for pykrx endpoints that need an authenticated KRX session.
KRX_ID=
KRX_PW=

# --- OpenDART ---------------------------------------------------------------
# Optional for the current OHLCV pipeline, required for future financial/account ingestion.
OPENDART_API_KEY=
# Comma-separated list of multiple OpenDART API keys. If set, this will be merged with OPENDART_API_KEY.
# OPENDART_API_KEYS=key1,key2,key3

# --- OpenDART all-years backfill script -------------------------------------
# Used by bin/dart-backfill-all-years.sh when set in the shell or scheduler.
# Defaults: start=2015, end=current year - 1, annual/half/quarterly reports, CFS+OFS.
# SDC_DART_BACKFILL_START_YEAR=2015
# SDC_DART_BACKFILL_END_YEAR=2025
# SDC_DART_BACKFILL_INCLUDE_CURRENT_YEAR=0
# SDC_DART_BACKFILL_REPRT_CODES=11011,11012,11013,11014
# SDC_DART_BACKFILL_FS_DIVS=CFS,OFS
# SDC_DART_BACKFILL_PULL_IMAGE=1

# --- Rate limiting -----------------------------------------------------------
RATE_LIMIT_SECONDS=0.2
# Take a long rest every N API requests (0 to disable).
LONG_REST_INTERVAL=100
# Duration of each long rest, in seconds.
LONG_REST_SECONDS=10.0

# --- Remote DB sync ---------------------------------------------------------
# Secret metadata file for the remote sj2-server PostgreSQL instance.
REMOTE_DB_INFO_PATH=/Users/whishaw/wss_p/stock_data_collector_secrets/db_info
# Remote sync batch size.
REMOTE_DB_BATCH_SIZE=50000
# Optional override if the host in db_info is not directly reachable.
# REMOTE_DB_HOST_OVERRIDE=
# Optional SSH host (for example, whi@sj2-server) when DB access requires a tunnel.
# REMOTE_DB_SSH_HOST=
# Optional fixed local port for the SSH tunnel.
# REMOTE_DB_SSH_LOCAL_PORT=

# --- Timezone (fixed in code, not configurable) ------------------------------
# TIMEZONE is always Asia/Seoul — not exposed as an env var.
