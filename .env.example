# =============================================================================
# KRX Data Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# --- Database (PostgreSQL) ---------------------------------------------------
# Preferred: single DSN string
DB_DSN=postgresql://krx_user:changeme@localhost:5432/krx_data

# Alternative: individual components (used if DB_DSN is empty)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=krx_data
# DB_USER=krx_user
# DB_PASSWORD=changeme

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=plain          # plain | json
# LOG_DIR=                # optional; set to enable rotating file handler

# --- Runtime -----------------------------------------------------------------
RUN_MODE=dev              # dev | prod

# --- Universe sync defaults --------------------------------------------------
UNIVERSE_SOURCE_DEFAULT=fdr    # fdr | pykrx

# --- Rate limiting -----------------------------------------------------------
RATE_LIMIT_SECONDS=0.2
# Take a long rest every N API requests (0 to disable).
LONG_REST_INTERVAL=100
# Duration of each long rest, in seconds.
LONG_REST_SECONDS=10.0

# --- Timezone (fixed in code, not configurable) ------------------------------
# TIMEZONE is always Asia/Seoul — not exposed as an env var.
